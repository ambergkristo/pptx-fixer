{
  "name": "pptx-fixer",
  "private": true,
  "type": "module",
  "scripts": {
    "audit": "node apps/audit-cli/runAudit.js",
    "build": "npm run ui:build",
    "corpus:report": "node tools/corpusReport.mjs",
    "corpus:test": "node scripts/runCorpusSuite.mjs",
    "fix": "node pptx-fixer",
    "generate:chaos-deck": "node scripts/generateChaosDeck.ts",
    "generate:master-acceptance-deck": "node scripts/generateMasterAcceptanceDeck.ts",
    "serve": "node apps/product-shell/server.ts",
    "start": "node apps/product-shell/server.ts",
    "validate:master-acceptance": "node scripts/runMasterAcceptanceValidation.ts",
    "validate:paragraph-spacing-stress-repro": "node scripts/runParagraphSpacingStressReproValidation.ts",
    "validate:recovery-gate": "node scripts/runRecoveryGateValidation.ts",
    "ui:dev": "vite --config apps/product-shell-ui/vite.config.ts",
    "ui:build": "vite build --config apps/product-shell-ui/vite.config.ts",
    "test": "node --test"
  },
  "dependencies": {
    "express": "^5.1.0",
    "fast-xml-parser": "5.2.5",
    "jszip": "3.10.1",
    "multer": "^2.0.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1"
  }
}
